<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.facerecognitionsystem.controller.MainController"
            fitToWidth="true"
            style="-fx-background-color: #f5f6fa; -fx-background: #f5f6fa;">

    <BorderPane prefHeight="680.0" prefWidth="900.0"
                style="-fx-background-color: #f5f6fa;">

        <top>
            <HBox alignment="CENTER" style="-fx-background-color: #ffffff; -fx-padding: 18; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                <Label text="Face Recognition System"
                       style="-fx-text-fill: #2d3436; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            </HBox>
        </top>

        <center>
            <VBox alignment="CENTER" spacing="16" style="-fx-padding: 30;">
                <StackPane style="-fx-background-color: #dfe6e9; -fx-border-color: #b2bec3; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;"
                           prefWidth="640" prefHeight="400">
                    <ImageView fx:id="cameraView"
                               fitWidth="640" fitHeight="400"
                               preserveRatio="true"/>
                    <Label text="Kamera belum aktif"
                           style="-fx-text-fill: #636e72; -fx-font-size: 14px;"/>
                </StackPane>

                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: #ffffff; -fx-padding: 16 30; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-width: 1;">
                    <Label fx:id="nameLabel" text="Terdeteksi: —"
                           style="-fx-text-fill: #2d3436; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label fx:id="confidenceLabel" text="Confidence: —"
                           style="-fx-text-fill: #636e72; -fx-font-size: 14px;"/>
                    <Label fx:id="timeLabel" text="Waktu: —"
                           style="-fx-text-fill: #b2bec3; -fx-font-size: 12px;"/>
                </VBox>

                <HBox alignment="CENTER" spacing="16" style="-fx-padding: 10 0 20 0;">
                    <Button fx:id="startButton" text="Mulai Kamera"
                            onAction="#handleStartCamera"
                            onMouseEntered="#onStartHover"
                            onMouseExited="#onStartExit"
                            style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 24; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Enroll Wajah Baru"
                            onAction="#handleEnroll"
                            onMouseEntered="#onGrayHover"
                            onMouseExited="#onGrayExit"
                            style="-fx-background-color: #636e72; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 24; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    <Button text="Lihat Riwayat"
                            onAction="#handleHistory"
                            onMouseEntered="#onGrayHover"
                            onMouseExited="#onGrayExit"
                            style="-fx-background-color: #636e72; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 24; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </center>

    </BorderPane>
</ScrollPane>