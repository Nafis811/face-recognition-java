<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.facerecognitionsystem.controller.MainController"
            stylesheets="@login.css" prefHeight="720" prefWidth="1180"
            styleClass="login-shell">
    <left>
        <VBox prefWidth="360" spacing="0" styleClass="brand-panel">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane prefWidth="46" prefHeight="46" styleClass="brand-mark">
                    <Label text="N" styleClass="brand-mark-text"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="NUSA LMS" styleClass="brand-name"/>
                    <Label text="SMART LEARNING PLATFORM" styleClass="brand-caption"/>
                </VBox>
            </HBox>

            <Region prefHeight="58"/>
            <Label text="Satu wajah, satu akses ke pembelajaran Anda." wrapText="true" styleClass="brand-headline"/>
            <Region prefHeight="14"/>
            <Label text="Masuk tanpa kata sandi dengan autentikasi wajah yang cepat dan praktis." wrapText="true" styleClass="brand-description"/>

            <Region prefHeight="45"/>
            <Label text="CARA MASUK" styleClass="section-eyebrow"/>
            <Region prefHeight="18"/>
            <VBox spacing="18">
                <HBox alignment="CENTER_LEFT" spacing="13">
                    <StackPane prefWidth="30" prefHeight="30" styleClass="step-number"><Label text="1" styleClass="step-number-text"/></StackPane>
                    <VBox spacing="2"><Label text="Aktifkan kamera" styleClass="step-title"/><Label text="Tekan tombol mulai pemindaian" styleClass="step-copy"/></VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="13">
                    <StackPane prefWidth="30" prefHeight="30" styleClass="step-number"><Label text="2" styleClass="step-number-text"/></StackPane>
                    <VBox spacing="2"><Label text="Posisikan wajah" styleClass="step-title"/><Label text="Hadapkan wajah ke area panduan" styleClass="step-copy"/></VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="13">
                    <StackPane prefWidth="30" prefHeight="30" styleClass="step-number"><Label text="3" styleClass="step-number-text"/></StackPane>
                    <VBox spacing="2"><Label text="Masuk otomatis" styleClass="step-title"/><Label text="Dashboard terbuka setelah dikenali" styleClass="step-copy"/></VBox>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="privacy-box">
                <Circle radius="4" styleClass="privacy-dot"/>
                <Label text="Kamera hanya dipakai untuk autentikasi" wrapText="true" styleClass="privacy-text"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <StackPane styleClass="content-area">
            <VBox alignment="TOP_CENTER" maxWidth="740" spacing="0" styleClass="login-card">
                <HBox alignment="CENTER_LEFT">
                    <VBox HBox.hgrow="ALWAYS" spacing="5">
                        <Label text="Masuk ke akun Anda" styleClass="login-title"/>
                        <Label text="Gunakan wajah yang sudah terdaftar di sistem" styleClass="login-subtitle"/>
                    </VBox>
                    <HBox alignment="CENTER" spacing="7" styleClass="system-status">
                        <Circle fx:id="serverStatusDot" radius="4" styleClass="status-dot"/>
                        <Label fx:id="serverStatusLabel" text="Memeriksa server..." styleClass="system-status-text"/>
                    </HBox>
                </HBox>

                <Region prefHeight="25"/>
                <StackPane prefWidth="680" minWidth="680" maxWidth="680"
                           prefHeight="360" minHeight="360" maxHeight="360"
                           styleClass="camera-frame">
                    <VBox fx:id="cameraPlaceholder" alignment="CENTER" spacing="12">
                        <StackPane prefWidth="68" prefHeight="68" styleClass="camera-icon-wrap">
                            <Label text="CAM" styleClass="camera-icon-text"/>
                        </StackPane>
                        <Label text="Kamera belum aktif" styleClass="camera-empty-title"/>
                        <Label text="Tekan tombol mulai untuk menampilkan kamera" styleClass="camera-empty-copy"/>
                    </VBox>
                    <ImageView fx:id="cameraView" fitWidth="680" fitHeight="360" preserveRatio="false" smooth="true"/>
                    <StackPane mouseTransparent="true" alignment="CENTER">
                        <Region prefWidth="220" prefHeight="280" maxWidth="220" maxHeight="280" styleClass="face-guide"/>
                    </StackPane>
                </StackPane>

                <Region prefHeight="20"/>
                <VBox alignment="CENTER" spacing="5">
                    <Label fx:id="nameLabel" text="Siap memindai wajah" styleClass="recognition-title"/>
                    <Label fx:id="confidenceLabel" text="Pastikan ruangan cukup terang dan wajah terlihat jelas" styleClass="recognition-copy"/>
                </VBox>

                <Region prefHeight="18"/>
                <Button fx:id="startButton" text="Mulai pemindaian wajah" onAction="#handleStartCamera"
                        maxWidth="330" minWidth="330" styleClass="primary-button"/>

                <Region prefHeight="13"/>
                <Button text="Lihat riwayat login" onAction="#handleHistory" styleClass="text-button"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
