<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.facerecognitionsystem.controller.DashboardController"
            prefHeight="720" prefWidth="1180" stylesheets="@app.css" styleClass="app-root">
    <left>
        <VBox prefWidth="240" spacing="8" styleClass="sidebar">
            <Label text="NUSA LMS" styleClass="sidebar-brand"/>
            <Label text="Learning Management System" wrapText="true" styleClass="sidebar-subtitle"/>
            <Region prefHeight="30"/>
            <Button text="Dashboard" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn-active"/>
            <Button text="Mata Kuliah" onAction="#handleMataKuliah" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn"/>
            <Button text="Tugas Saya" onAction="#handleTugas" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn"/>
            <Button text="Jadwal" onAction="#handleJadwal" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Keluar" onAction="#handleLogout" maxWidth="Infinity" styleClass="sidebar-logout"/>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="24" style="-fx-padding: 36 40 36 40;">
                <!-- Header Section -->
                <HBox alignment="CENTER_LEFT">
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label fx:id="welcomeLabel" text="Selamat datang!" styleClass="title-primary"/>
                        <Label fx:id="dateLabel" styleClass="subtitle-primary"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="4" style="-fx-background-color: #f0fdf4; -fx-padding: 8 16; -fx-background-radius: 12; -fx-border-color: #dcfce7; -fx-border-width: 1;">
                        <Label text="● TERVERIFIKASI FACE ID" style="-fx-text-fill: #16a34a; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;"/>
                        <Label fx:id="profileNameLabel" style="-fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Stats Area -->
                <HBox spacing="18">
                    <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card-widget, stat-card-blue">
                        <Label text="MATA KULIAH" styleClass="stat-label-title"/>
                        <Label fx:id="mataKuliahCountLabel" text="..." style="-fx-text-fill: #1d4ed8; -fx-font-size: 26px; -fx-font-weight: 800;"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card-widget, stat-card-orange">
                        <Label text="TUGAS AKTIF" styleClass="stat-label-title"/>
                        <Label fx:id="tugasCountLabel" text="..." style="-fx-text-fill: #ea580c; -fx-font-size: 26px; -fx-font-weight: 800;"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card-widget, stat-card-green">
                        <Label text="PROGRES BELAJAR" styleClass="stat-label-title"/>
                        <Label fx:id="progresLabel" text="..." style="-fx-text-fill: #16a34a; -fx-font-size: 26px; -fx-font-weight: 800;"/>
                    </VBox>
                </HBox>

                <!-- Course Cards Area -->
                <VBox spacing="14">
                    <Label text="Mata Kuliah Saya" styleClass="section-title"/>
                    <HBox spacing="18">
                        <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="card-widget">
                            <Label text="Pemrograman Berorientasi Objek" wrapText="true" style="-fx-text-fill: #1e3a8a; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Label text="👨‍🏫 M. Bayu Wibisono, S.Kom.,MM" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            <Region prefHeight="4"/>
                            <ProgressBar progress="0.82" maxWidth="Infinity" styleClass="progress-bar"/>
                            <Label text="Progres Belajar: 82%" style="-fx-text-fill: #2563eb; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="card-widget">
                            <Label text="Sistem Basis Data" style="-fx-text-fill: #166534; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Label text="👨‍🏫 Iin Ernawati S.Kom., M.Si" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                            <Region prefHeight="4"/>
                            <ProgressBar progress="0.68" maxWidth="Infinity" styleClass="progress-bar, progress-bar-green"/>
                            <Label text="Progres Belajar: 68%" style="-fx-text-fill: #10b981; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Tasks Area -->
                <VBox spacing="14">
                    <Label text="Tugas Mendatang" styleClass="section-title"/>
                    <!-- Container Tugas dengan Drop Shadow Halus -->
                    <VBox fx:id="tugasMendatangContainer" spacing="0"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.05), 14, 0, 0, 2); -fx-padding: 8;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
