<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.facerecognitionsystem.controller.DashboardController"
            prefHeight="720" prefWidth="1050" style="-fx-background-color: #f4f7fb;">
    <left>
        <VBox prefWidth="215" spacing="10" style="-fx-background-color: #172554; -fx-padding: 28 18;">
            <Label text="NUSA LMS" style="-fx-text-fill: white; -fx-font-size: 23px; -fx-font-weight: bold;"/>
            <Label text="Learning Management System" wrapText="true" style="-fx-text-fill: #93c5fd; -fx-font-size: 10px;"/>
            <Region prefHeight="25"/>
            <Button text="Dashboard" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 8;"/>
            <Button text="Mata Kuliah" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #dbeafe; -fx-padding: 12;"/>
            <Button text="Tugas Saya" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #dbeafe; -fx-padding: 12;"/>
            <Button text="Jadwal" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #dbeafe; -fx-padding: 12;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Keluar" onAction="#handleLogout" maxWidth="Infinity" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-padding: 11; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #f4f7fb; -fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 30;">
                <HBox alignment="CENTER_LEFT">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label fx:id="welcomeLabel" text="Selamat datang!" style="-fx-text-fill: #0f172a; -fx-font-size: 25px; -fx-font-weight: bold;"/>
                        <Label fx:id="dateLabel" style="-fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Login dengan Face ID" style="-fx-text-fill: #16a34a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="profileNameLabel" style="-fx-text-fill: #334155;"/>
                    </VBox>
                </HBox>
                <HBox spacing="14">
                    <VBox spacing="7" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;"><Label text="MATA KULIAH" style="-fx-text-fill: #64748b;"/><Label text="5 Aktif" style="-fx-text-fill: #2563eb; -fx-font-size: 23px; -fx-font-weight: bold;"/></VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;"><Label text="TUGAS" style="-fx-text-fill: #64748b;"/><Label text="3 Belum selesai" style="-fx-text-fill: #ea580c; -fx-font-size: 23px; -fx-font-weight: bold;"/></VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;"><Label text="PROGRES" style="-fx-text-fill: #64748b;"/><Label text="78%" style="-fx-text-fill: #16a34a; -fx-font-size: 23px; -fx-font-weight: bold;"/></VBox>
                </HBox>
                <Label text="Mata Kuliah Saya" style="-fx-text-fill: #0f172a; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <HBox spacing="14">
                    <VBox spacing="9" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;"><Label text="Pemrograman Berorientasi Objek" wrapText="true" style="-fx-text-fill: #1e3a8a; -fx-font-size: 16px; -fx-font-weight: bold;"/><Label text="Dosen Pengampu" style="-fx-text-fill: #64748b;"/><ProgressBar progress="0.82" maxWidth="Infinity"/><Label text="Progres 82%" style="-fx-text-fill: #2563eb;"/></VBox>
                    <VBox spacing="9" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;"><Label text="Basis Data" style="-fx-text-fill: #166534; -fx-font-size: 16px; -fx-font-weight: bold;"/><Label text="Dosen Pengampu" style="-fx-text-fill: #64748b;"/><ProgressBar progress="0.68" maxWidth="Infinity"/><Label text="Progres 68%" style="-fx-text-fill: #16a34a;"/></VBox>
                </HBox>
                <Label text="Tugas Mendatang" style="-fx-text-fill: #0f172a; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <VBox spacing="1" style="-fx-background-color: #e2e8f0; -fx-padding: 1;">
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 16;"><Label text="UAS - Aplikasi OOP" HBox.hgrow="ALWAYS" style="-fx-font-weight: bold;"/><Label text="28 Juni 2026" style="-fx-text-fill: #dc2626;"/></HBox>
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 16;"><Label text="Normalisasi Database" HBox.hgrow="ALWAYS" style="-fx-font-weight: bold;"/><Label text="30 Juni 2026" style="-fx-text-fill: #ea580c;"/></HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
