<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.facerecognitionsystem.controller.JadwalController"
            prefHeight="720" prefWidth="1180" stylesheets="@app.css" styleClass="app-root">
    <left>
        <VBox prefWidth="240" spacing="8" styleClass="sidebar">
            <Label text="NUSA LMS" styleClass="sidebar-brand"/>
            <Label text="Learning Management System" wrapText="true" styleClass="sidebar-subtitle"/>
            <Region prefHeight="30"/>
            <Button text="Dashboard" onAction="#handleDashboard" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn"/>
            <Button text="Mata Kuliah" onAction="#handleMataKuliah" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn"/>
            <Button text="Tugas Saya" onAction="#handleTugas" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn"/>
            <Button text="Jadwal" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="sidebar-btn-active"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Keluar" onAction="#handleLogout" maxWidth="Infinity" styleClass="sidebar-logout"/>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="24" style="-fx-padding: 36 40 36 40;">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label text="Jadwal Kuliah" styleClass="title-primary"/>
                        <Label text="Jadwal perkuliahan mingguan Anda beserta ruangan dan jam belajar" styleClass="subtitle-primary"/>
                    </VBox>
                </HBox>
                <!-- Container untuk Card Jadwal -->
                <VBox fx:id="jadwalContainer" spacing="16"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>